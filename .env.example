FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret

DATABASE_URL=sqlite:///signaldash_dev.sqlite3

SIGNALDASH_STORAGE_ROOT=/srv/signaldash/storage
SIGNALDASH_INGEST_ROOT=/srv/signaldash/ingest
SIGNALDASH_BACKUP_ROOT=/srv/signaldash/backups
SIGNALDASH_LOG_ROOT=/srv/signaldash/logs

REDIS_URL=redis://localhost:6379/0

OLLAMA_BASE_URL=http://localhost:11434
LOCAL_TRIAGE_MODEL=qwen2.5-coder:3b
LOCAL_EXTRACTION_MODEL=qwen2.5-coder:7b
LOCAL_SUMMARY_MODEL=llama3.1:8b

OPENAI_API_KEY=
OPENAI_ENABLED=false
OPENAI_DEFAULT_MODEL=gpt-4o-mini

DAILY_AI_SOFT_LIMIT_USD=2
DAILY_AI_HARD_LIMIT_USD=10
MONTHLY_AI_SOFT_LIMIT_USD=30
MONTHLY_AI_HARD_LIMIT_USD=100
